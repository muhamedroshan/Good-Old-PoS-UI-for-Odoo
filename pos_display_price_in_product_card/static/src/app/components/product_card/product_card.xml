<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_display_price_in_product_card.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-content')]" position="after">
            <span t-if="price" class="product-price px-2 py-0" style="font-size: 0.75rem; color:#71639e;  ">
                <t t-esc="price" />
            </span>
        </xpath>
    </t>
</templates>